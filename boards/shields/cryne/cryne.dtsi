#include <dt-bindings/zmk/matrix_transform.h>

/ {
  chosen {
    zmk,kscan = &kscan0;
    zmk,matrix-transform = &default_transform;
  };

  split_central: split_central {
    compatible = "zmk,split-central";
  };

  split_peripheral: split_peripheral {
    compatible = "zmk,split-peripheral";
  };

  default_transform: keymap_transform0 {
    compatible = "zmk,matrix-transform";
    columns = <14>;  // 7 columns per side (5 main + 2 thumb)
    rows = <4>;      // 4 rows: bottom, home, top, thumb
    map = <
      // Left side: Row 0 (bottom) - 5 main keys
      RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
      // Right side: Row 0 (bottom) - 5 main keys  
      RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
      
      // Left side: Row 1 (home) - 5 main keys
      RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
      // Right side: Row 1 (home) - 5 main keys
      RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
      
      // Left side: Row 2 (top) - 5 main keys
      RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
      // Right side: Row 2 (top) - 5 main keys
      RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
      
      // Left side: Row 3 (thumb) - 2 thumb keys
      RC(3,5) RC(3,6)
      // Right side: Row 3 (thumb) - 2 thumb keys
      RC(3,12) RC(3,13)
    >;
  };

  kscan0: kscan0 {
    compatible = "zmk,kscan-gpio-matrix";
    diode-direction = "col2row";
    // wakeup-source;  // DISABLED - can cause issues with some clones

    // Debounce settings (prevent accidental double-press)
    debounce-press-ms = <5>;
    debounce-release-ms = <5>;
  };
};
